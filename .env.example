# =============================================================================
# jp-opendata-actors 環境変数の骨子（引継書§5準拠）
# 使い方: cp .env.example .env して値を埋める。.envはコミットしない（.gitignore済み）。
# 本番（Apify上）ではApify Secretsで設定する。この.envはローカル開発・fixture採取用。
# シークレットをコード・fixture・goldenに含めないこと（引継書§13）。
# =============================================================================

# --- データ源APIキー（Actor別） -----------------------------------------------

# Actor#1 EDINET: 金融庁 EDINET API v2 の Subscription-Key（クエリパラメータで送る）
# 取得: EDINET APIの利用登録（要件書§2では取得済み）。未設定だとHTTP 200＋body StatusCode=401が返る
EDINET_API_KEY=

# Actor#2 補助金 / Actor#4 法人エンリッチ: gBizINFO APIトークン
# v2でも認証はv1と同じヘッダ `X-hojinInfo-api-token`（docs/research/gbizinfo-v2.md）
# 取得: gBizINFO Web API利用申請フォーム（取得済み）
GBIZINFO_API_TOKEN=

# Actor#3 不動産取引価格: 不動産情報ライブラリのAPIキー（ヘッダ `Ocp-Apim-Subscription-Key`）
# 状態: 審査中（目安5営業日）。キーのブラウザ直叩き転用は規約上不可（サーバ実行のみ）
REINFOLIB_API_KEY=

# Actor#4 法人エンリッチ: 国税庁 法人番号Web-API Ver.4 のアプリケーションID（13桁、クエリ id=）
# 状態: 審査中（1〜1.5ヶ月）＝#4の公開ゲート。検証環境も本番と同一IDが必要（仮IDなし）
HOUJIN_APP_ID=

# Actor#5 法令: e-Gov法令API v2 は登録不要・キー不要（環境変数なし）

# --- LLM enrichment（#1 enriched / #4 enriched / #5 translated で使用） --------

# Anthropic APIキー（enrich実行時のみ必要。basic出力だけなら不要）
ANTHROPIC_API_KEY=

# enrichに使うモデル（既定: claude-haiku-4-5）
ENRICH_MODEL=claude-haiku-4-5

# 原価計算用のモデル単価 USD/Mtok（N-2: 単価改定を検知したら再計測）
# claude-haiku-4-5 の定価は入力$1.00/出力$5.00。enrichはBatch API既定（50%オフ）のため実効単価を設定
ENRICH_PRICE_IN=0.50
ENRICH_PRICE_OUT=2.50

# 為替換算（既定155円/USD。要件書の原価・マージン計算に使用）
FX_JPY_PER_USD=155

# --- 監視・通知（N-4） ---------------------------------------------------------

# 実行終端アラートのPOST先（Slack Incoming Webhook等）。未設定ならログのみ
ALERT_WEBHOOK_URL=

# --- ローカル開発・テスト用（本番では設定しない） -------------------------------

# Apify PPE課金のローカルテスト: 全イベント$1扱いでActor.chargeを有効化
# ACTOR_TEST_PAY_PER_EVENT=true
# 課金ログを storage/datasets/charging_log/ に出力
# ACTOR_USE_CHARGING_LOG_DATASET=true

# golden更新は環境変数を直接設定せず `pnpm golden:update` を使うこと（CI上では禁止）
